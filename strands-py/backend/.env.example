# AWS Bedrodk
AWS_ACCESS_KEY_ID=XXXX
AWS_SECRET_ACCESS_KEY=XXXX
AWS_REGION=us-west-2
AWS_BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-5-20250929-v1:0

# Streaming 時のソケット read 待ち上限（秒）。未設定時はアプリ既定 300
AWS_BEDROCK_READ_TIMEOUT=300
# 任意: 接続確立のタイムアウト（秒）
# AWS_BEDROCK_CONNECT_TIMEOUT=60

AWS_MAX_TOKENS=8192

# Brave Search API Key
BRAVE_API_KEY=XXXX